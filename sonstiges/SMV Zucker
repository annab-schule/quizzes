<body>
<div class="page">

  <div class="header">
    <span class="emoji">🍭</span>
    <div class="title">Zuckerwatte-Stand</div>
    <div class="subtitle">SMV-Kalkulation · Schulparty</div>
    <div class="badge">Verkaufspreis: 2,00 €</div>
    <div class="badge2">✓ Echte Zahlen · 1. Event 20.03.2026</div>
  </div>

  <!-- STARTKOSTEN -->

  <p class="section-title">💰 Startkosten (einmalig)</p>
  <div class="card">
    <table class="cost-table">
      <tr>
        <td>🍢 Holzstäbchen (520 Stück)
          <span class="sub">3 Pakete · tatsächlicher Einkauf</span>
        </td>
        <td>26,46 €</td>
      </tr>
      <tr>
        <td>🍬 Farbzucker (3 Packungen)
          <span class="sub">tatsächlicher Einkauf · je ~1 kg / 8,68 €</span>
        </td>
        <td>25,43 €</td>
      </tr>
      <tr>
        <td>🍚 Normaler Zucker (3 Packungen)
          <span class="sub">tatsächlicher Einkauf · je 1 kg / 1,39 €</span>
        </td>
        <td>4,17 €</td>
      </tr>
      <tr class="total-row">
        <td>Gesamt Startinvestition (Material)</td>
        <td>56,06 €</td>
      </tr>
    </table>
  </div>

  <div class="strip"></div>

  <!-- KOSTEN PRO PORTION -->

  <p class="section-title">🔍 Kosten pro Portion <span class="erfahrung-badge">Erfahrungswert ✓</span></p>
  <div class="card">
    <table class="cost-table">
      <tr>
        <td>🍢 Stäbchen (inkl. ~25% Ausschuss)
          <span class="sub">210 Stück für 170 Portionen · 0,051 € / Stück</span>
        </td>
        <td>0,063 €</td>
      </tr>
      <tr>
        <td>🍬 Farbzucker (~6 g / Portion, erste 50 Portionen)
          <span class="sub">danach normaler Zucker · gemittelter Wert</span>
        </td>
        <td>0,051 €</td>
      </tr>
      <tr>
        <td>🍚 Normaler Zucker (~14 g / Portion, ab Portion 51)
          <span class="sub">gemittelter Wert über alle 170 Portionen</span>
        </td>
        <td>0,020 €</td>
      </tr>
      <tr class="abschr-row">
        <td>⚙️ Maschinenabschreibung (anteilig)
          <span class="sub">250 € ÷ 15 Events (5 Jahre) = 16,67 € / Event ÷ 170 Portionen</span>
        </td>
        <td>0,098 €</td>
      </tr>
      <tr class="total-row">
        <td>Vollkosten pro Portion</td>
        <td>0,232 €</td>
      </tr>
    </table>
  </div>

  <div class="three-highlights">
    <div class="highlight-box">
      <div class="highlight-big">0,13 €</div>
      <div class="highlight-label">Wareneinsatz<br>pro Portion</div>
    </div>
    <div class="highlight-box orange">
      <div class="highlight-big">0,10 €</div>
      <div class="highlight-label">Abschreibung<br>pro Portion</div>
    </div>
    <div class="highlight-box green">
      <div class="highlight-big">1,77 €</div>
      <div class="highlight-label">Deckungsbeitrag<br>(nach Vollkosten)</div>
    </div>
  </div>

  <div class="lager-box">
    📦 <strong>Lagerbestand nach 1. Event:</strong> noch 310 Stäbchen (~15,81 €) · noch 2 Packungen Farbzucker (~17,36 €) → Startmaterial für Event 2 bereits vorhanden!
  </div>

  <div class="strip"></div>

  <!-- ZEITPLANUNG -->

  <p class="section-title">⏱️ Zeitplanung · 1 Person</p>
  <div class="time-grid">
    <div class="time-card">
      <div class="time-num">30 Sek</div>
      <div class="time-label">pro Zuckerwatte</div>
    </div>
    <div class="time-card">
      <div class="time-num">120</div>
      <div class="time-label">Portionen / Stunde möglich</div>
    </div>
    <div class="time-card">
      <div class="time-num">~85 Min</div>
      <div class="time-label">für 170 Portionen</div>
    </div>
    <div class="time-card">
      <div class="time-num">170</div>
      <div class="time-label">Portionen / Event (Erfahrungswert ✓)</div>
    </div>
  </div>

  <div class="strip"></div>

  <!-- PREISVERGLEICH -->

  <p class="section-title">📊 Ergebnisübersicht · 170 Portionen</p>
  <div class="card">
    <table class="price-table">
      <thead>
        <tr>
          <th>Preis</th>
          <th>Einnahmen</th>
          <th>Wareneinsatz</th>
          <th>Abschreibung</th>
          <th>Gewinn</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>1,50 €</td>
          <td>255,00 €</td>
          <td>22,73 €</td>
          <td>16,67 €</td>
          <td>+215,60 €</td>
        </tr>
        <tr class="winner">
          <td>2,00 €</td>
          <td>340,00 €</td>
          <td>22,73 €</td>
          <td>16,67 €</td>
          <td>+300,60 €</td>
        </tr>
        <tr>
          <td>2,50 €</td>
          <td>425,00 €</td>
          <td>22,73 €</td>
          <td>16,67 €</td>
          <td>+385,60 €</td>
        </tr>
      </tbody>
    </table>
  </div>
  <p style="font-size:0.78rem;color:#999;margin-top:0.4rem;padding-left:0.3rem;">* Abschreibung: 250 € ÷ 15 Events (5 Jahre · 3 Events/Jahr)</p>

  <div class="strip"></div>

  <!-- EVENT VERGLEICH -->

  <p class="section-title">🎉 1. vs. 2. Event</p>
  <div class="event-grid">
    <div class="event-card">
      <div class="event-title">1. Event (tatsächlich)</div>
      <div class="event-num" style="color:#2e7d32;">+267 €</div>
      <div class="event-detail" style="color:#555;">
        Einnahmen: 340,00 €<br>
        Wareneinsatz: 22,73 €<br>
        Restl. Startmaterial: 33,33 €<br>
        Abschreibung: 16,67 €<br>
        <span style="font-size:0.72rem;color:#43a047;">Sofort im Plus! ✓</span>
      </div>
    </div>
    <div class="event-card second">
      <div class="event-title">Ab 2. Event</div>
      <div class="event-num">+301 €</div>
      <div class="event-detail">
        Einnahmen: 340,00 €<br>
        Wareneinsatz: ~23 €<br>
        Abschreibung: 16,67 €<br>
        <span style="font-size:0.72rem;color:#ff9f43;">Stäbchen + Farbzucker<br>teils noch aus Lager</span>
      </div>
    </div>
  </div>

  <div class="tipp-box">
    💡 <strong>SMV-Tipp:</strong> Schon das erste Event bringt <strong>+267 € Gewinn</strong> – selbst nach Abschreibung! Ab dem zweiten Event sind es rund <strong>301 € pro Veranstaltung</strong>. Bei 3 Events im Jahr macht der Stand über <strong>850 € für die SMV-Kasse</strong>. 🚀
  </div>

  <!-- FOLGEKOSTEN -->

  <p class="section-title">🔄 Nachkauf für 2. Event (Schätzung)</p>
  <div class="card">
    <table class="cost-table">
      <tr>
        <td>🍢 Stäbchen-Nachkauf (nur falls nötig)
          <span class="sub">310 Stück noch im Lager – reicht für ~150 Portionen</span>
        </td>
        <td>~0–14 €</td>
      </tr>
      <tr>
        <td>🍬 Farbzucker (2 Pkg noch vorhanden)
          <span class="sub">reicht für ~100 Portionen Farbzucker</span>
        </td>
        <td>0,00 €</td>
      </tr>
      <tr>
        <td>🍚 Normaler Zucker Nachkauf
          <span class="sub">~3 kg · 3 × 1,39 €</span>
        </td>
        <td>~4,17 €</td>
      </tr>
      <tr class="total-row">
        <td>Gesamt Nachkauf Event 2</td>
        <td>~4–18 €</td>
      </tr>
    </table>
  </div>

  <div class="strip"></div>

  <div class="footer">
    Erstellt für die SMV · Gymnasium Wendelstein · Schulparty-Kalkulation · Echte Zahlen vom 1. Event 20.03.2026
  </div>

</div>
